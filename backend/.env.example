# Allowed CORS origins (comma-separated). Defaults cover Vite dev + preview.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Phase 2: directory containing Liam's joblib model artifacts.
# Each file named like `{target}_{model}.joblib` (e.g., n_xgboost.joblib).
# MODEL_DIR=./models

# Phase 3: Copernicus Data Space credentials for live Sentinel-2 fetch.
# Register at https://dataspace.copernicus.eu
# COPERNICUS_USER=
# COPERNICUS_PASS=

# Override the source label returned in /predict responses
# (useful when running with placeholder values vs. real models).
# ML_SOURCE_LABEL=placeholder
