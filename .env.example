# Optional: URL of the SoilScan ML prediction backend (FastAPI service in `backend/`).
# When set, the webapp's mlPredictionService fetches per-location predictions from
# `${VITE_ML_API_URL}/predict?location=...`. When unset or unreachable, the webapp
# falls back to the bundled static JSON at `src/data/mlPredictions.json`.
# VITE_ML_API_URL=http://localhost:8000

# URL of Hans's rule-based fertilizer recommendation engine (Railway).
# The webapp's recommendationService POSTs to ${VITE_RULE_API_URL}/recommendation.
# Vite inlines this at build time — changing it requires a rebuild.
# When unset or unreachable, falls back to local stub implementation.
VITE_RULE_API_URL=https://soilscanrulebased-production.up.railway.app
# Local dev override (engine running on Hans's run_final.bat):
# VITE_RULE_API_URL=http://localhost:8001

# Existing optional integrations
# VITE_KIMI_API_KEY=
